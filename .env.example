# Copy this file to .env and fill in real values. .env is gitignored.
# Compose reads these automatically for ${VAR} interpolation in
# docker-compose.yaml. Required values use ${VAR:?...} and will halt
# `docker compose up` if missing; everything else is optional.

# === Required secrets ===
# Generate strong unique values locally, e.g.:
#   openssl rand -hex 32   (JWT_SECRET)
#   openssl rand -hex 24   (POSTGRES_PASSWORD)
# Keep JWT_SECRET stable — changing it invalidates all existing sessions.
JWT_SECRET=

# === Database (Compose assembles DATABASE_URL from these) ===
# POSTGRES_PASSWORD is only applied when the postgres volume is first
# created. If you change it after the DB has initialized, you must reset
# the volume or rotate the password inside Postgres directly.
POSTGRES_USER=postiz-user
POSTGRES_PASSWORD=
POSTGRES_DB=postiz-db-local

# === Social / API keys — fill in as needed; blank = integration disabled ===
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BEEHIIVE_API_KEY=
BEEHIIVE_PUBLICATION_ID=
THREADS_APP_ID=
THREADS_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# === AI / Payments ===
OPENAI_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_KEY=
STRIPE_SIGNING_KEY_CONNECT=
